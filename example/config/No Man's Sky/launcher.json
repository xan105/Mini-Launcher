{
  "bin": "Binaries/NMS.exe",
  "env": {
    "SteamAppId": "275850",
    "SteamGameId": "275850",
    "SteamClientLaunch": "1",
    "SteamEnv": "1",
    "SteamPath": "%PROCESS%",
    "GAMEPAD_API_XINPUT": "HOOK",
    "ANYLUA_FILEPATH": "%CURRENTDIR%\\Addons\\AnyLua.lua"
  },
  "script": {
    "path": "Steamclient/steamclient.lua",
    "fs": true,
    "reg": true
  },
  "wait": true,
  "suspended": true,
