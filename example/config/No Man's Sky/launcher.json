    "show": true,
    "image": ["splash.bmp"],
    "timeout": 10,
    "wait": "FOREGROUND"
  },
  "symlink": [
    {
      "path": "%APPDATA%/HelloGames/NMS",
      "dest": "%SAVEGAME%/No Man's Sky"
    }
  ],
  "shortcut": {
    "name": "No Man's Sky",
    "startmenu": true
  },
